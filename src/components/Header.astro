---
const currentPath = Astro.url.pathname;
const navLinkBase = 'inline-flex items-center h-full text-wood-700 hover:text-fire-600 font-medium transition-colors border-b-2 border-transparent pb-1';
---

<nav class="bg-white shadow-md sticky top-0 z-50">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-20">
      <!-- Logo/Brand -->
      <a href="/" class="flex items-center space-x-3">
        <div class="text-2xl font-heading font-bold text-wood-800">
          Woodstock Farina
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        <a
          href="/"
          class={`${navLinkBase} ${currentPath === '/' ? 'text-fire-600 border-fire-600' : ''}`}
        >
          Home
        </a>
        <a
          href="/menu"
          class={`${navLinkBase} ${currentPath === '/menu' ? 'text-fire-600 border-fire-600' : ''}`}
        >
          Menu
        </a>
        <a
          href="/about"
          class={`${navLinkBase} ${currentPath === '/about' ? 'text-fire-600 border-fire-600' : ''}`}
        >
          About
        </a>
        <a
          href="/gallery"
          class={`${navLinkBase} ${currentPath === '/gallery' ? 'text-fire-600 border-fire-600' : ''}`}
        >
          Gallery
        </a>
        <a
          href="/contact"
          class={`${navLinkBase} ${currentPath === '/contact' ? 'text-fire-600 border-fire-600' : ''}`}
        >
          Contact
        </a>
        <a
          href="/booking"
          class="bg-fire-600 text-white px-6 py-2 rounded-full font-semibold hover:bg-fire-700 transition-colors"
        >
          Book Event
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden text-wood-800 focus:outline-none"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col space-y-3">
        <a href="/" class="text-wood-700 hover:text-fire-600 font-medium py-2">Home</a>
        <a href="/menu" class="text-wood-700 hover:text-fire-600 font-medium py-2">Menu</a>
        <a href="/about" class="text-wood-700 hover:text-fire-600 font-medium py-2">About</a>
        <a href="/gallery" class="text-wood-700 hover:text-fire-600 font-medium py-2">Gallery</a>
        <a href="/contact" class="text-wood-700 hover:text-fire-600 font-medium py-2">Contact</a>
        <a href="/booking" class="bg-fire-600 text-white px-6 py-2 rounded-full font-semibold hover:bg-fire-700 transition-colors text-center">
          Book Event
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  menuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
