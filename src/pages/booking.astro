---
import Layout from '../layouts/Layout.astro';

const packages = [
  {
    name: "Small Gathering",
    servings: "Up to 30 guests",
    basePrice: "Starting at $800"
  },
  {
    name: "Medium Event",
    servings: "30-75 guests",
    basePrice: "Starting at $1,500"
  },
  {
    name: "Large Celebration",
    servings: "75-150 guests",
    basePrice: "Starting at $2,500"
  },
  {
    name: "Custom Package",
    servings: "150+ guests",
    basePrice: "Contact for quote"
  }
];
---

<Layout
  title="Book Your Event - Woodstock Farina | Check Availability"
  description="Book authentic wood-fired pizza catering for your event in Ventura County. Check availability and reserve your date today."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-wood-800 to-wood-900 text-white py-20">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-5xl md:text-6xl font-heading font-bold mb-4">
        Book Your Event
      </h1>
      <p class="text-xl text-wood-100 max-w-2xl mx-auto">
        Let's make your celebration unforgettable with authentic wood-fired pizza
      </p>
    </div>
  </section>

  <!-- Booking Form -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="bg-wood-50 p-8 md:p-12 rounded-lg shadow-xl">
          <form class="space-y-8" id="booking-form">
            <!-- Event Information -->
            <div>
              <h2 class="text-2xl font-heading font-bold text-wood-900 mb-6 pb-3 border-b-2 border-fire-600">
                Event Information
              </h2>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="event-date" class="block text-wood-700 font-medium mb-2">
                    Event Date *
                  </label>
                  <input
                    type="date"
                    id="event-date"
                    name="event-date"
                    required
                    min={new Date().toISOString().split('T')[0]}
                    class="w-full px-4 py-3 border border-wood-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fire-600 focus:border-transparent"
                  />
                </div>

                <div>
                  <label for="event-time" class="block text-wood-700 font-medium mb-2">
                    Start Time *
                  </label>
                  <input
                    type="time"
                    id="event-time"
                    name="event-time"
                    required
                    class="w-full px-4 py-3 border border-wood-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fire-600 focus:border-transparent"
                  />
                </div>

                <div>
                  <label for="event-type" class="block text-wood-700 font-medium mb-2">
                    Event Type *
                  </label>
                  <select
                    id="event-type"
                    name="event-type"
                    required
                    class="w-full px-4 py-3 border border-wood-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fire-600 focus:border-transparent"
                  >
                    <option value="">Select event type</option>
                    <option value="wedding">Wedding</option>
                    <option value="corporate">Corporate Event</option>
                    <option value="birthday">Birthday Party</option>
                    <option value="anniversary">Anniversary</option>
                    <option value="graduation">Graduation</option>
                    <option value="fundraiser">Fundraiser/Nonprofit</option>
                    <option value="other">Other</option>
                  </select>
                </div>

                <div>
                  <label for="guest-count" class="block text-wood-700 font-medium mb-2">
                    Number of Guests *
                  </label>
                  <input
                    type="number"
                    id="guest-count"
                    name="guest-count"
                    required
                    min="20"
                    placeholder="e.g., 75"
                    class="w-full px-4 py-3 border border-wood-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fire-600 focus:border-transparent"
                  />
                </div>
              </div>

              <div class="mt-6 relative">
                <label for="venue-location" class="block text-wood-700 font-medium mb-2">
                  Venue/Location *
                </label>
                <input
                  type="text"
                  id="venue-location"
                  name="venue-location"
                  required
                  placeholder="Venue name and city"
                  autocomplete="off"
                  class="w-full px-4 py-3 border border-wood-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fire-600 focus:border-transparent"
                />
                <input type="hidden" id="venue-location-id" name="venue-location-id" />
                <input type="hidden" id="venue-location-label" name="venue-location-label" />
                <ul
                  id="venue-suggestions"
                  class="hidden absolute z-30 mt-1 w-full bg-white border border-wood-200 rounded-lg shadow-lg max-h-56 overflow-auto"
                  role="listbox"
                ></ul>
                <p class="text-xs text-wood-500 mt-2">
                  Start typing and select a suggested address so we can verify the venue location.
                </p>
              </div>

              <div class="mt-6 flex flex-col sm:flex-row sm:items-center gap-4">
                <button
                  type="button"
                  id="check-availability-btn"
                  class="bg-wood-900 text-white px-6 py-3 rounded-full font-semibold hover:bg-wood-800 transition-colors"
                >
                  Check Availability
                </button>
                <p class="text-sm text-wood-600">
                  Check date and time before submitting your booking request.
                </p>
              </div>

              <div
                id="booking-status"
                class="mt-4 hidden rounded-lg px-4 py-3 text-sm"
                role="status"
                aria-live="polite"
              ></div>
            </div>

            <!-- Package Selection -->
            <div>
              <h2 class="text-2xl font-heading font-bold text-wood-900 mb-6 pb-3 border-b-2 border-fire-600">
                Select Package
              </h2>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {packages.map((pkg) => (
                  <label class="relative cursor-pointer">
                    <input
                      type="radio"
                      name="package"
                      value={pkg.name}
                      required
                      class="peer sr-only"
                    />
                    <div class="bg-white p-6 rounded-lg border-2 border-wood-300 peer-checked:border-fire-600 peer-checked:bg-fire-50 transition-all hover:border-fire-400">
                      <div class="flex items-start justify-between mb-2">
                        <h3 class="font-heading font-bold text-lg text-wood-900">
                          {pkg.name}
                        </h3>
                        <div class="w-5 h-5 rounded-full border-2 border-wood-300 peer-checked:border-fire-600 peer-checked:bg-fire-600 flex items-center justify-center">
                          <svg class="w-3 h-3 text-white hidden peer-checked:block" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                          </svg>
                        </div>
                      </div>
                      <div class="text-fire-600 font-semibold mb-2">{pkg.servings}</div>
                      <div class="text-wood-600">{pkg.basePrice}</div>
                    </div>
                  </label>
                ))}
              </div>

              <p class="text-sm text-wood-600 mt-4">
                <strong>Note:</strong> Final pricing will be provided in your quote based on guest count,
                package selection, and any special requests.
              </p>
            </div>

            <!-- Contact Information -->
            <div>
              <h2 class="text-2xl font-heading font-bold text-wood-900 mb-6 pb-3 border-b-2 border-fire-600">
                Your Information
              </h2>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="full-name" class="block text-wood-700 font-medium mb-2">
                    Full Name *
                  </label>
                  <input
                    type="text"
                    id="full-name"
                    name="full-name"
                    required
                    placeholder="John Doe"
                    class="w-full px-4 py-3 border border-wood-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fire-600 focus:border-transparent"
                  />
                </div>

                <div>
                  <label for="email" class="block text-wood-700 font-medium mb-2">
                    Email Address *
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="your@email.com"
                    class="w-full px-4 py-3 border border-wood-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fire-600 focus:border-transparent"
                  />
                </div>

                <div>
                  <label for="phone" class="block text-wood-700 font-medium mb-2">
                    Phone Number *
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    placeholder="(555) 123-4567"
                    class="w-full px-4 py-3 border border-wood-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fire-600 focus:border-transparent"
                  />
                </div>

                <div>
                  <label for="preferred-contact" class="block text-wood-700 font-medium mb-2">
                    Preferred Contact Method
                  </label>
                  <select
                    id="preferred-contact"
                    name="preferred-contact"
                    class="w-full px-4 py-3 border border-wood-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fire-600 focus:border-transparent"
                  >
                    <option value="email">Email</option>
                    <option value="phone">Phone Call</option>
                    <option value="text">Text Message</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Special Requests -->
            <div>
              <h2 class="text-2xl font-heading font-bold text-wood-900 mb-6 pb-3 border-b-2 border-fire-600">
                Special Requests
              </h2>

              <div class="space-y-4">
                <div>
                  <label class="flex items-start gap-3 cursor-pointer">
                    <input
                      type="checkbox"
                      name="dietary-vegetarian"
                      class="mt-1 w-5 h-5 text-fire-600 border-wood-300 rounded focus:ring-2 focus:ring-fire-600"
                    />
                    <div>
                      <div class="font-medium text-wood-900">Vegetarian Options Needed</div>
                      <div class="text-sm text-wood-600">We'll include vegetarian pizza options</div>
                    </div>
                  </label>
                </div>

                <div>
                  <label class="flex items-start gap-3 cursor-pointer">
                    <input
                      type="checkbox"
                      name="dietary-vegan"
                      class="mt-1 w-5 h-5 text-fire-600 border-wood-300 rounded focus:ring-2 focus:ring-fire-600"
                    />
                    <div>
                      <div class="font-medium text-wood-900">Vegan Options Needed</div>
                      <div class="text-sm text-wood-600">We'll use plant-based cheese and toppings</div>
                    </div>
                  </label>
                </div>

                <div>
                  <label class="flex items-start gap-3 cursor-pointer">
                    <input
                      type="checkbox"
                      name="dietary-gluten-free"
                      class="mt-1 w-5 h-5 text-fire-600 border-wood-300 rounded focus:ring-2 focus:ring-fire-600"
                    />
                    <div>
                      <div class="font-medium text-wood-900">Gluten-Free Crust Available</div>
                      <div class="text-sm text-wood-600">Limited availability, please specify quantity</div>
                    </div>
                  </label>
                </div>
              </div>

              <div class="mt-6">
                <label for="additional-notes" class="block text-wood-700 font-medium mb-2">
                  Additional Notes or Requests
                </label>
                <textarea
                  id="additional-notes"
                  name="additional-notes"
                  rows="4"
                  placeholder="Tell us about any allergies, specific pizza requests, setup requirements, or other details we should know..."
                  class="w-full px-4 py-3 border border-wood-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fire-600 focus:border-transparent resize-none"
                ></textarea>
              </div>
            </div>

            <!-- Submit Button -->
            <div class="pt-4">
              <button
                type="submit"
                id="submit-booking-btn"
                disabled
                class="w-full bg-fire-600 text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-fire-700 transition-all transform hover:scale-105 shadow-lg disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none"
              >
                Submit Booking Request
              </button>

              <div
                id="booking-status-bottom"
                class="mt-4 hidden rounded-lg px-4 py-3 text-sm text-left"
                role="status"
                aria-live="polite"
              ></div>

              <p class="text-sm text-wood-600 mt-4 text-center">
                By submitting this form, you'll receive a quote and confirmation within 24 hours.
                We'll reach out to discuss details and secure your date with a deposit.
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-wood-50">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-heading font-bold text-wood-900 mb-4">
            How It Works
          </h2>
          <p class="text-lg text-wood-600">
            Simple steps from booking to your event
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-fire-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
              1
            </div>
            <h3 class="font-heading font-bold text-wood-900 mb-2">Submit Request</h3>
            <p class="text-wood-600 text-sm">
              Fill out the booking form with your event details
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-fire-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
              2
            </div>
            <h3 class="font-heading font-bold text-wood-900 mb-2">Get Quote</h3>
            <p class="text-wood-600 text-sm">
              Receive a custom quote within 24 hours
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-fire-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
              3
            </div>
            <h3 class="font-heading font-bold text-wood-900 mb-2">Secure Date</h3>
            <p class="text-wood-600 text-sm">
              Pay 50% deposit to confirm your booking
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-fire-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
              4
            </div>
            <h3 class="font-heading font-bold text-wood-900 mb-2">Enjoy!</h3>
            <p class="text-wood-600 text-sm">
              We handle everything on your event day
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Contact -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-heading font-bold text-wood-900 mb-4">
          Prefer to Talk First?
        </h2>
        <p class="text-lg text-wood-600 mb-6">
          Have questions or want to discuss your event before booking?
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="tel:6617546510"
            class="bg-fire-600 text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-fire-700 transition-all transform hover:scale-105"
          >
            Call (661) 754-6510
          </a>
          <a
            href="/contact"
            class="bg-white border-2 border-fire-600 text-fire-600 px-8 py-4 rounded-full font-semibold text-lg hover:bg-fire-50 transition-all transform hover:scale-105"
          >
            Send Message
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement | null;
  const availabilityButton = document.getElementById('check-availability-btn') as HTMLButtonElement | null;
  const submitButton = document.getElementById('submit-booking-btn') as HTMLButtonElement | null;
  const statusBox = document.getElementById('booking-status') as HTMLDivElement | null;
  const statusBoxBottom = document.getElementById('booking-status-bottom') as HTMLDivElement | null;
  const venueInput = document.getElementById('venue-location') as HTMLInputElement | null;
  const venueLocationIdInput = document.getElementById('venue-location-id') as HTMLInputElement | null;
  const venueLocationLabelInput = document.getElementById('venue-location-label') as HTMLInputElement | null;
  const venueSuggestionList = document.getElementById('venue-suggestions') as HTMLUListElement | null;

  const availabilityState = {
    checked: false,
    available: false,
    signature: '',
  };

  const locationState = {
    selected: false,
    selectedLabel: '',
    selectedId: '',
  };

  let locationQueryTimer: number | undefined;
  let locationLookupAbortController: AbortController | null = null;
  let locationRequestSequence = 0;
  let lastAppliedLocationRequest = 0;

  interface LocationSuggestion {
    id: string;
    label: string;
    lat: string;
    lon: string;
  }

  let activeSuggestions: LocationSuggestion[] = [];
  const suggestionCache = new Map<string, LocationSuggestion[]>();

  const statusStyles = {
    info: 'bg-wood-100 text-wood-800 border border-wood-200',
    success: 'bg-green-100 text-green-900 border border-green-200',
    error: 'bg-red-100 text-red-900 border border-red-200',
  };

  const statusStyleTokens = Object.values(statusStyles).flatMap((classes) => classes.split(' '));

  const setStatus = (message: string, tone: keyof typeof statusStyles) => {
    const boxes = [statusBox, statusBoxBottom].filter(Boolean) as HTMLDivElement[];
    boxes.forEach((box) => {
      box.classList.remove('hidden', ...statusStyleTokens);
      box.classList.add(...statusStyles[tone].split(' '));
      box.textContent = message;
    });
  };

  const getAvailabilityPayload = () => {
    const date = (document.getElementById('event-date') as HTMLInputElement | null)?.value ?? '';
    const time = (document.getElementById('event-time') as HTMLInputElement | null)?.value ?? '';
    const guestCount = (document.getElementById('guest-count') as HTMLInputElement | null)?.value ?? '';
    const venueLocation = (document.getElementById('venue-location') as HTMLInputElement | null)?.value ?? '';

    return {
      eventDate: date,
      eventTime: time,
      guestCount,
      venueLocation,
      durationHours: 3,
    };
  };

  const buildSignature = () => {
    const payload = getAvailabilityPayload();
    return `${payload.eventDate}|${payload.eventTime}|${payload.guestCount}|${payload.venueLocation}`;
  };

  const invalidateAvailability = () => {
    availabilityState.checked = false;
    availabilityState.available = false;
    availabilityState.signature = '';
    if (submitButton) {
      submitButton.disabled = true;
    }
  };

  const hideVenueSuggestions = () => {
    if (!venueSuggestionList) {
      return;
    }

    venueSuggestionList.classList.add('hidden');
    venueSuggestionList.innerHTML = '';
  };

  const showVenueSuggestionMessage = (message: string) => {
    if (!venueSuggestionList) {
      return;
    }

    venueSuggestionList.innerHTML = '';
    const item = document.createElement('li');
    item.className = 'px-4 py-3 text-sm text-wood-500';
    item.textContent = message;
    venueSuggestionList.appendChild(item);
    venueSuggestionList.classList.remove('hidden');
  };

  const setVerifiedVenue = (suggestion: LocationSuggestion) => {
    if (!venueInput || !venueLocationIdInput || !venueLocationLabelInput) {
      return;
    }

    venueInput.value = suggestion.label;
    venueLocationIdInput.value = suggestion.id;
    venueLocationLabelInput.value = suggestion.label;
    locationState.selected = true;
    locationState.selectedLabel = suggestion.label;
    locationState.selectedId = suggestion.id;
  };

  const invalidateVenueSelection = () => {
    locationState.selected = false;
    locationState.selectedLabel = '';
    locationState.selectedId = '';
    if (venueLocationIdInput) {
      venueLocationIdInput.value = '';
    }
    if (venueLocationLabelInput) {
      venueLocationLabelInput.value = '';
    }
  };

  const renderVenueSuggestions = (suggestions: LocationSuggestion[]) => {
    if (!venueSuggestionList) {
      return;
    }

    venueSuggestionList.innerHTML = '';

    if (!suggestions.length) {
      hideVenueSuggestions();
      return;
    }

    suggestions.forEach((suggestion) => {
      const item = document.createElement('li');
      item.className = 'px-4 py-3 text-sm text-wood-700 hover:bg-wood-100 cursor-pointer border-b border-wood-100 last:border-b-0';
      item.textContent = suggestion.label;
      item.setAttribute('role', 'option');

      item.addEventListener('mousedown', (event) => {
        event.preventDefault();
        setVerifiedVenue(suggestion);
        hideVenueSuggestions();
      });

      venueSuggestionList.appendChild(item);
    });

    venueSuggestionList.classList.remove('hidden');
  };

  const fetchVenueSuggestions = async (query: string) => {
    const cacheKey = query.toLowerCase();
    const cachedSuggestions = suggestionCache.get(cacheKey);
    if (cachedSuggestions) {
      activeSuggestions = cachedSuggestions;
      renderVenueSuggestions(activeSuggestions);
      return;
    }

    const requestSequence = ++locationRequestSequence;

    if (locationLookupAbortController) {
      locationLookupAbortController.abort();
    }

    locationLookupAbortController = new AbortController();
    showVenueSuggestionMessage('Searching locations...');

    try {
      const response = await fetch(`/api/location-suggest?q=${encodeURIComponent(query)}`, {
        signal: locationLookupAbortController.signal,
      });

      if (!response.ok) {
        throw new Error(`Suggestion lookup failed: ${response.status}`);
      }

      const result = await response.json();

      if (requestSequence < lastAppliedLocationRequest) {
        return;
      }

      lastAppliedLocationRequest = requestSequence;
      activeSuggestions = (result.suggestions ?? []) as LocationSuggestion[];

      suggestionCache.set(cacheKey, activeSuggestions);
      renderVenueSuggestions(activeSuggestions);
    } catch (error) {
      if (error instanceof DOMException && error.name === 'AbortError') {
        return;
      }

      console.error('Venue suggestions lookup failed:', error);

      if (requestSequence < lastAppliedLocationRequest) {
        return;
      }

      lastAppliedLocationRequest = requestSequence;
      activeSuggestions = [];
      showVenueSuggestionMessage('Could not load suggestions. Keep typing or try again in a moment.');
    }
  };

  venueInput?.addEventListener('input', () => {
    const query = venueInput.value.trim();

    if (query !== locationState.selectedLabel) {
      invalidateVenueSelection();
    }

    if (availabilityState.checked) {
      invalidateAvailability();
      setStatus('Event details changed. Please re-check availability.', 'info');
    }

    if (locationQueryTimer) {
      window.clearTimeout(locationQueryTimer);
    }

    if (query.length < 3) {
      activeSuggestions = [];
      hideVenueSuggestions();
      return;
    }

    locationQueryTimer = window.setTimeout(() => {
      fetchVenueSuggestions(query);
    }, 250);
  });

  venueInput?.addEventListener('blur', () => {
    window.setTimeout(() => {
      hideVenueSuggestions();

      if (venueInput.value.trim() && venueInput.value.trim() !== locationState.selectedLabel) {
        invalidateVenueSelection();
      }
    }, 150);
  });

  venueInput?.addEventListener('focus', () => {
    const query = venueInput.value.trim();
    if (query.length >= 3 && !locationState.selected) {
      fetchVenueSuggestions(query);
    }
  });

  document.addEventListener('click', (event) => {
    if (!venueSuggestionList || !venueInput) {
      return;
    }

    const target = event.target as Node;
    if (!venueSuggestionList.contains(target) && target !== venueInput) {
      hideVenueSuggestions();
    }
  });

  const watchFields = ['event-date', 'event-time', 'guest-count', 'venue-location'];
  watchFields.forEach((id) => {
    const field = document.getElementById(id);
    field?.addEventListener('change', () => {
      if (availabilityState.checked) {
        invalidateAvailability();
        setStatus('Event details changed. Please re-check availability.', 'info');
      }
    });
  });

  availabilityButton?.addEventListener('click', async () => {
    const payload = getAvailabilityPayload();

    if (!payload.eventDate || !payload.eventTime || !payload.guestCount || !payload.venueLocation) {
      setStatus('Add date, time, guest count, and venue before checking availability.', 'error');
      return;
    }

    if (!locationState.selected) {
      setStatus('Select a suggested venue/location so we can verify the address.', 'error');
      return;
    }

    availabilityButton.disabled = true;
    availabilityButton.textContent = 'Checking...';

    try {
      const response = await fetch('/api/check-availability', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
      });

      const result = await response.json();
      if (result.available) {
        availabilityState.checked = true;
        availabilityState.available = true;
        availabilityState.signature = buildSignature();
        if (submitButton) {
          submitButton.disabled = false;
        }
        setStatus(result.message ?? 'Date is available for booking.', 'success');
      } else {
        invalidateAvailability();
        setStatus(result.message ?? 'Date is unavailable. Please choose another time.', 'error');
      }
    } catch (error) {
      console.error('Availability check failed:', error);
      invalidateAvailability();
      setStatus('Unable to check availability right now. Please try again.', 'error');
    } finally {
      availabilityButton.disabled = false;
      availabilityButton.textContent = 'Check Availability';
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!availabilityState.available || availabilityState.signature !== buildSignature()) {
      setStatus('Please check availability with your latest event details before submitting.', 'error');
      if (submitButton) {
        submitButton.disabled = true;
      }
      return;
    }

    if (!locationState.selected) {
      setStatus('Please select a suggested venue/location before submitting.', 'error');
      return;
    }

    if (!form.reportValidity()) {
      return;
    }

    const formData = new FormData(form);
    const data: Record<string, unknown> = Object.fromEntries(formData.entries());
    data['dietary-vegetarian'] = formData.has('dietary-vegetarian');
    data['dietary-vegan'] = formData.has('dietary-vegan');
    data['dietary-gluten-free'] = formData.has('dietary-gluten-free');
    data.durationHours = 3;

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = 'Submitting...';
    }
    if (availabilityButton) {
      availabilityButton.disabled = true;
    }

    try {
      const response = await fetch('/api/create-booking', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        setStatus(result.message ?? 'Booking request failed. Please try again.', 'error');
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = 'Submit Booking Request';
        }
        if (availabilityButton) {
          availabilityButton.disabled = false;
        }
        return;
      }

      const requestIdMessage = result.requestId ? ` Request ID: ${result.requestId}.` : '';
      setStatus(`${result.message ?? 'Booking request submitted successfully.'}${requestIdMessage}`, 'success');

      form.reset();
      invalidateAvailability();
    } catch (error) {
      console.error('Booking submit failed:', error);
      setStatus('Something went wrong while submitting your request. Please try again.', 'error');
    } finally {
      if (submitButton) {
        submitButton.textContent = 'Submit Booking Request';
      }
      if (availabilityButton) {
        availabilityButton.disabled = false;
      }
    }
  });

  // Set minimum date to tomorrow
  const dateInput = document.getElementById('event-date') as HTMLInputElement;
  if (dateInput) {
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    dateInput.min = tomorrow.toISOString().split('T')[0];
  }
</script>
