  },
  {
    name: 'Caesar Salad',
    description: 'Romaine lettuce, freshly shaved Parmesan, and croutons, tossed with Caesar dressing',
  },
  {
    name: 'Fresh Beet Salad *',
    description: 'Roasted golden beets, spring mix, goat cheese, golden raisins, pistachios, tossed in olive oil and red wine vinegar',
    specialty: true,
  },
  {
    name: 'Strawberry Spinach Salad *',
    description: 'Baby spinach, strawberry halves, walnuts, crumbled feta cheese tossed with balsamic vinegar',
    specialty: true,
  },
  {
    name: 'Tomato Burrata Salad *',
    description: 'Baby tomato halves with burrata, diced red onion, fresh basil, parsley, salt, pepper, and chopped garlic, tossed in basil oil and red wine vinegar',
    specialty: true,
  },
  {
    name: 'Esquite Inspired Street Corn Salad *',
    description: 'Roasted fire corn, cilantro, diced peppers, red onion, Cotija cheese, queso fresco, green onion, salt, pepper, lime zest, lemon juice, and mayonnaise',
    specialty: true,
  },
  {
    name: 'Summer Peach Salad *',
    description: 'Fresh sliced peaches and heirloom tomatoes with fresh basil, tossed with balsamic glaze and basil oil, topped with flaky salt',
    specialty: true,
  },
];

const appetizers = [
  {
    name: 'Garlic Bread',
    description: 'Garlic butter and Parmesan cheese',
  },
  {
    name: 'Wood-fired Meatballs',
    description: 'Pork and beef meatballs roasted and served over a house-made tomato sauce',
  },
  {
    name: 'Caprese Skewers',
    description: 'Mozzarella balls, cherry tomatoes, and fresh basil',
  },
  {
    name: 'Bruschetta',
    description: 'Diced tomatoes with garlic and fresh basil drizzled with balsamic glaze and served over toasted baguette slices',
  },
  {
    name: 'Oven Roasted Wings *',
    description: 'Seasoned chicken wings finished in our ovens',
    specialty: true,
    options: ['Lime Mezcal', 'Lemon Pepper', 'Garlic Herb', 'Naked Wings (No Finishing Sauce)'],
  },
  {
    name: 'Burrata Bruschetta *',
    description: 'Diced tomatoes, garlic, basil, and olive oil served with fresh burrata on toasted baguette slices',
    specialty: true,
  },
