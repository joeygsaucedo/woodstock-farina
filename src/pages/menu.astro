    description: 'Breadcrumbs, bacon, onion, feta cheese, garlic, and chives',
    specialty: true,
  },
  {
    name: 'Steak Crostini *',
    description: 'Sliced steak, sauteed mushrooms, burrata, and chimichurri',
    specialty: true,
  },
  {
    name: 'Caramelized Onions & Blue Cheese Crostini *',
    description: 'Topped with chopped chives',
    specialty: true,
  },
  {
    name: 'Smoked Salmon & Cream Cheese *',
    description: 'Smoked salmon, cream cheese, capers, and dill',
    specialty: true,
  },
];

const packages = [
  {
    name: 'Fire y Fiesta',
    price: '$48 per person',
    description: 'A selection of 3 pizzas, 2 appetizers, 2 salads, and a 4 ft grazing table.',
  },
  {
    name: 'Sabor Social',
    price: '$35 per person',
    description: 'A selection of 3 pizzas, 2 appetizers, and 1 salad.',
  },
  {
    name: 'Amigos y Appetites',
    price: '$30 per person',
    description: 'A selection of 3 pizzas and 1 salad.',
  },
  {
    name: 'Slices de Sabores',
    price: '$25 per person',
    description: 'A selection of 3 pizzas.',
  },
];

const grazingLayouts = [
  {
    name: 'Flatlay',
    description: 'Presentations are made directly on a flat surface on food-safe parchment paper.',
    sizes: ['4 ft: $600 - Serves 25-35', '6 ft: $800 - Serves 40-55', '8 ft: $1000 - Serves 60-75', '10 ft: $1400 - Serves 80-100'],
  },
  {
    name: 'Multi-Dimensional',
    description: 'Includes various boxes, risers, or stands to create a uniquely visually appealing display.',
    sizes: ['6 ft: $1000 - Serves 40-55', '8 ft: $1250 - Serves 60-75', '10 ft: $1700 - Serves 80-100', '12 ft: $2100 - Serves 105-120'],
  },
];

const grazingIncludes = [
  '4 hard cheeses',
  '2 soft cheeses',
  'Selection of cured meats',
  'Seasonal fruits and vegetables',
  '1 craft spread',
  'Local honey',
  '4 pickled or marinated items',
  'Selection of artisanal crackers',
  '2 nuts',
  '2 dried fruits',
  'Fresh greenery and edible flowers',
];
---

<Layout
  title="Menu - Woodstock Farina | Wood-Fired Pizza"
  description="Explore our artisanal wood-fired pizzas with traditional and Mexican-inspired flavors. Catering packages available for events of all sizes."
>
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-wood-800 to-wood-900 text-white py-20">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-5xl md:text-6xl font-heading font-bold mb-4">
        Our Menu
      </h1>
      <p class="text-xl text-wood-100 max-w-2xl mx-auto">
        Every pizza is hand-crafted and cooked to perfection in our wood-fired oven
      </p>
    </div>
  </section>

  <!-- Pizza Menu -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl md:text-5xl font-heading font-bold text-wood-900 mb-4">
            Meal Options
          </h2>
          <p class="text-lg text-wood-600 max-w-3xl mx-auto">
            Our meal options are designed to fit weddings, parties, and corporate events of every size.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          {packages.map((pkg) => (
            <div class="bg-wood-50 p-6 rounded-lg shadow hover:shadow-lg transition-shadow border-l-4 border-fire-600">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-3">
                <h3 class="text-2xl font-heading font-bold text-wood-900">{pkg.name}</h3>
                <div class="text-fire-600 font-semibold">{pkg.price}</div>
              </div>
              <p class="text-wood-600">{pkg.description}</p>
            </div>
          ))}
        </div>

        <div class="bg-fire-50 border border-fire-100 rounded-lg p-5 mb-16 text-wood-700">
          <p class="font-medium mb-2">Important pricing note</p>
          <p>
            Appetizers, salads, and grazing tables not included in your meal selection are available at an additional per person cost.
            Specialty menu selections marked with an asterisk incur an additional fee of $300 per event.
          </p>
        </div>

        <div class="mb-16">
          <h2 class="text-3xl font-heading font-bold text-wood-900 mb-2 pb-2 border-b-2 border-fire-600 inline-block">
            Pizza Selection
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
            {pizzas.map((pizza) => (
              <div class={`bg-wood-50 p-6 rounded-lg shadow hover:shadow-lg transition-shadow ${pizza.specialty ? 'border-l-4 border-fire-600' : ''}`}>
                <div class="flex justify-between items-start mb-2">
                  <h3 class="text-xl font-heading font-bold text-wood-900">
                    {pizza.name}
                  </h3>
                  <div class="flex gap-2 flex-wrap justify-end">
                    {pizza.specialty && (
                      <span class="text-xs bg-fire-100 text-fire-800 px-2 py-1 rounded">
                        Specialty +$300/event
                      </span>
                    )}
                    {pizza.vegetarian && (
                      <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded">
                        Vegetarian
                      </span>
                    )}
                  </div>
                </div>
                <p class="text-wood-600">
                  {pizza.description}
                </p>
              </div>
            ))}
          </div>
        </div>

        <div class="mb-16">
          <h2 class="text-3xl font-heading font-bold text-wood-900 mb-2 pb-2 border-b-2 border-fire-600 inline-block">
            Salads
          </h2>
          <p class="text-wood-600 mt-4 mb-8">
            Standard salad selections are priced at $8 per person. Specialty salad options are marked below.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {salads.map((salad) => (
              <div class={`bg-wood-50 p-6 rounded-lg shadow hover:shadow-lg transition-shadow ${salad.specialty ? 'border-l-4 border-fire-600' : ''}`}>
                <div class="flex justify-between items-start mb-2">
                  <h3 class="text-xl font-heading font-bold text-wood-900">
                    {salad.name}
                  </h3>
                  {salad.specialty && (
                    <span class="text-xs bg-fire-100 text-fire-800 px-2 py-1 rounded">
                      Specialty +$300/event
                    </span>
                  )}
                </div>
                <p class="text-wood-600">
                  {salad.description}
                </p>
              </div>
            ))}
          </div>
        </div>

        <div class="mb-16">
          <h2 class="text-3xl font-heading font-bold text-wood-900 mb-2 pb-2 border-b-2 border-fire-600 inline-block">
            Appetizers
          </h2>
          <p class="text-wood-600 mt-4 mb-8">
            Appetizers range from $8 to $15 per person depending on your selections.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
            {appetizers.map((item) => (
              <div class={`bg-wood-50 p-6 rounded-lg shadow hover:shadow-lg transition-shadow ${item.specialty ? 'border-l-4 border-fire-600' : ''}`}>
                <div class="flex justify-between items-start mb-2">
                  <h3 class="text-xl font-heading font-bold text-wood-900">
                    {item.name}
                  </h3>
                  {item.specialty && (
                    <span class="text-xs bg-fire-100 text-fire-800 px-2 py-1 rounded">
                      Specialty +$300/event
                    </span>
                  )}
                </div>
                <p class="text-wood-600">
                  {item.description}
                </p>
                {item.options && (
                  <ul class="mt-4 flex flex-wrap gap-2">
                    {item.options.map((option) => (
                      <li class="text-xs bg-white border border-wood-200 text-wood-700 px-2 py-1 rounded-full">{option}</li>
                    ))}
                  </ul>
                )}
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-3xl font-heading font-bold text-wood-900 mb-2 pb-2 border-b-2 border-fire-600 inline-block">
            Grazing Table
          </h2>
          <p class="text-wood-600 mt-4 mb-8 leading-relaxed">
            We can arrange a beautiful grazing table for your event full of cured meats, artisanal cheeses, breads and crackers,
            seasonal fruits and vegetables, pickled items, dried fruit and nuts, dips, honey, and jams.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
            {grazingLayouts.map((layout) => (
              <div class="bg-wood-50 p-6 rounded-lg shadow hover:shadow-lg transition-shadow">
                <h3 class="text-2xl font-heading font-bold text-wood-900 mb-2">{layout.name}</h3>
                <p class="text-wood-600 mb-4">{layout.description}</p>
                <ul class="space-y-2 text-wood-700">
                  {layout.sizes.map((size) => (
                    <li>{size}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

          <div class="bg-white border border-wood-200 rounded-lg p-6">
            <p class="text-wood-700 mb-4">
              Pricing includes food for the suggested guest count, serving utensils/tongs, and lush greenery.
              Multi-dimensional layouts include live setup. Clean up service is available for an additional fee of $100-$150,
              and plates, cutlery, and napkins may be added for $1.50 per person.
            </p>
            <h3 class="text-xl font-heading font-bold text-wood-900 mb-3">Standard 6-8 ft table includes</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-wood-700">
              {grazingIncludes.map((item) => (
                <div class="bg-wood-50 px-3 py-2 rounded">{item}</div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Catering Packages -->
  <section class="py-20 bg-wood-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-heading font-bold text-wood-900 mb-4">
          Why Guests Love It
        </h2>
        <p class="text-lg text-wood-600 max-w-2xl mx-auto">
          Wood-fired service, seasonal ingredients, and flexible menu formats built for memorable events.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {[
          {
            title: 'Wood-fired service on site',
            body: 'Every event is cooked live in our oven for the smoky flavor and crisp crust that define Woodstock Farina.',
          },
          {
            title: 'Flexible catering formats',
            body: 'Build from pizzas only, full meal packages, or add appetizers, salads, and a full grazing table.',
          },
          {
            title: 'Specialty upgrades available',
            body: 'Seasonal and premium menu selections marked with an asterisk can be added for a flat specialty event fee.',
          },
        ].map((feature) => (
          <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow">
            <h3 class="text-2xl font-heading font-bold text-wood-900 mb-2">
              {feature.title}
            </h3>
            <p class="text-wood-600 mb-6">
              {feature.body}
            </p>
            <a href="/booking" class="inline-block text-fire-600 font-semibold hover:text-fire-700 transition-colors">
              Build Your Event Menu →
            </a>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <p class="text-wood-600 mb-4">
          Need a custom package or a grazing table tailored to your guest count? We are happy to work with you.
        </p>
        <a
          href="/contact"
          class="inline-block text-fire-600 font-semibold hover:text-fire-700 transition-colors"
        >
          Contact Us for Custom Quotes →
        </a>
      </div>
    </div>
  </section>

  <!-- Additional Info -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-wood-50 p-6 rounded-lg">
          <h3 class="text-xl font-heading font-bold text-wood-900 mb-3">
            🔥 Wood-Fired Perfection
          </h3>
          <p class="text-wood-600">
            Every pizza is cooked at 800°F in our authentic wood-fired oven, creating the perfect crispy crust
            and smoky flavor that can't be replicated in a conventional oven.
          </p>
        </div>

        <div class="bg-wood-50 p-6 rounded-lg">
          <h3 class="text-xl font-heading font-bold text-wood-900 mb-3">
            🌱 Fresh Ingredients
          </h3>
          <p class="text-wood-600">
            We use fresh seasonal produce, quality cheeses, and house-built combinations designed to stand out at catered events.
          </p>
        </div>

        <div class="bg-wood-50 p-6 rounded-lg">
          <h3 class="text-xl font-heading font-bold text-wood-900 mb-3">
            🎨 Customization Available
          </h3>
          <p class="text-wood-600">
            Have dietary restrictions or special requests? Let us know when booking and we can help shape a menu around your event.
          </p>
        </div>

        <div class="bg-wood-50 p-6 rounded-lg">
          <h3 class="text-xl font-heading font-bold text-wood-900 mb-3">
            ⭐ Specialty Selection Note
          </h3>
          <p class="text-wood-600">
            Menu items marked with an asterisk are specialty selections and add $300 per event when included.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-br from-fire-600 to-fire-700 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
        Ready to Book?
      </h2>
      <p class="text-xl mb-8 max-w-2xl mx-auto">
        Check our availability and reserve your date today!
      </p>
      <a
        href="/booking"
        class="inline-block bg-white text-fire-600 px-8 py-4 rounded-full font-semibold text-lg hover:bg-wood-50 transition-all transform hover:scale-105"
      >
        Check Availability
      </a>
    </div>
  </section>
</Layout>
