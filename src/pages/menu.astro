    description: 'Prosciutto, cantaloupe, and arugula',
    specialty: true,
  },
  {
    name: 'Shrimp Scampi Crostini *',
    description: 'Roasted shrimp in scampi sauce drizzled with chimichurri',
    specialty: true,
  },
