---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Us - Woodstock Farina | Our Story"
  description="Learn about Victor Melchor and the story behind Woodstock Farina. Celebrating Mexican heritage through authentic wood-fired pizza catering in Ventura County."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-wood-800 to-wood-900 text-white py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-heading font-bold mb-6">
          Our Story
        </h1>
        <p class="text-xl text-wood-100 leading-relaxed">
          Celebrating the art of cooking with smoke—a tradition deeply rooted in our Mexican heritage
        </p>
      </div>
    </div>
  </section>

  <!-- Victor's Story -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-16">
          <div class="rounded-lg overflow-hidden shadow-xl">
            <img
              src="/images/team/victor.jpg"
              alt="Victor Melchor - Founder of Woodstock Farina"
              class="w-full h-96 object-cover"
            />
          </div>
          <div>
            <h2 class="text-4xl font-heading font-bold text-wood-900 mb-6">
              Meet Victor Melchor
            </h2>
            <p class="text-lg text-wood-700 mb-4 leading-relaxed">
              Growing up in a Mexican household, I was surrounded by the rich tradition of cooking with fire and smoke.
              From carne asada on open flames to homemade tortillas, food was always at the heart of our family gatherings.
            </p>
            <p class="text-lg text-wood-700 mb-4 leading-relaxed">
              When I discovered the art of wood-fired pizza making, I saw an opportunity to blend my heritage with
              artisanal pizza-making traditions. The result? Woodstock Farina—where authentic Mexican flavors meet
              the timeless craft of wood-fired cooking.
            </p>
            <p class="text-lg text-wood-700 leading-relaxed">
              Every pizza we make honors both traditions, cooked at 800°F in our mobile wood-fired oven,
              bringing that unique smoky flavor to events across Ventura County.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Heritage & Tradition -->
  <section class="py-20 bg-wood-50">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl md:text-5xl font-heading font-bold text-wood-900 mb-4">
            Heritage & Tradition
          </h2>
          <p class="text-lg text-wood-600">
            Where Mexican cooking traditions meet Italian craftsmanship
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-8 rounded-lg shadow-lg text-center">
            <div class="text-5xl mb-4">🔥</div>
            <h3 class="text-xl font-heading font-bold text-wood-900 mb-3">
              Wood-Fired Tradition
            </h3>
            <p class="text-wood-600">
              Cooking with wood fire is central to Mexican cuisine—from street tacos to traditional barbacoa.
              We honor this tradition in every pizza we make.
            </p>
          </div>

          <div class="bg-white p-8 rounded-lg shadow-lg text-center">
            <div class="text-5xl mb-4">🌽</div>
            <h3 class="text-xl font-heading font-bold text-wood-900 mb-3">
              Mexican Flavors
            </h3>
            <p class="text-wood-600">
              From al pastor to street corn, we incorporate authentic Mexican ingredients and recipes
              into our pizzas, creating unique flavor combinations.
            </p>
          </div>

          <div class="bg-white p-8 rounded-lg shadow-lg text-center">
            <div class="text-5xl mb-4">🍕</div>
            <h3 class="text-xl font-heading font-bold text-wood-900 mb-3">
              Artisanal Craft
            </h3>
            <p class="text-wood-600">
              Each pizza is hand-stretched and crafted with care, using traditional techniques
              perfected over years of practice and dedication.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Wood-Fired Process -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl md:text-5xl font-heading font-bold text-wood-900 mb-4">
            The Wood-Fired Process
          </h2>
          <p class="text-lg text-wood-600">
            What makes wood-fired pizza special
          </p>
        </div>

        <div class="space-y-8">
          <div class="flex flex-col md:flex-row gap-6 items-start">
            <div class="flex-shrink-0 w-16 h-16 bg-fire-600 text-white rounded-full flex items-center justify-center text-2xl font-bold">
              1
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-heading font-bold text-wood-900 mb-2">
                High Temperature
              </h3>
              <p class="text-wood-600 text-lg">
                Our oven reaches 800°F, creating the perfect environment for a crispy crust with a soft,
                chewy interior. This temperature can't be achieved in conventional ovens.
              </p>
            </div>
            <img
              src="/images/team/oven-fire.jpg"
              alt="Wood fire in oven"
              class="w-48 h-32 object-cover rounded-lg shadow-md hidden md:block"
            />
          </div>

          <div class="flex flex-col md:flex-row gap-6 items-start">
            <div class="flex-shrink-0 w-16 h-16 bg-fire-600 text-white rounded-full flex items-center justify-center text-2xl font-bold">
              2
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-heading font-bold text-wood-900 mb-2">
                Smoky Flavor
              </h3>
              <p class="text-wood-600 text-lg">
                Wood smoke infuses each pizza with a unique, subtle smokiness that adds depth and character.
                This is the signature of authentic wood-fired cooking.
              </p>
            </div>
            <img
              src="/images/team/pizza-making.jpg"
              alt="Making pizza"
              class="w-48 h-32 object-cover rounded-lg shadow-md hidden md:block"
            />
          </div>

          <div class="flex flex-col md:flex-row gap-6 items-start">
            <div class="flex-shrink-0 w-16 h-16 bg-fire-600 text-white rounded-full flex items-center justify-center text-2xl font-bold">
              3
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-heading font-bold text-wood-900 mb-2">
                Quick Cooking
              </h3>
              <p class="text-wood-600 text-lg">
                Pizzas cook in just 90 seconds to 2 minutes at these high temperatures, locking in freshness
                and ensuring your guests are served quickly at events.
              </p>
            </div>
            <img
              src="/images/pizzas/margherita.jpg"
              alt="Fresh pizza"
              class="w-48 h-32 object-cover rounded-lg shadow-md hidden md:block"
            />
          </div>

          <div class="flex flex-col md:flex-row gap-6 items-start">
            <div class="flex-shrink-0 w-16 h-16 bg-fire-600 text-white rounded-full flex items-center justify-center text-2xl font-bold">
              4
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-heading font-bold text-wood-900 mb-2">
                Perfect Char
              </h3>
              <p class="text-wood-600 text-lg">
                The intense heat creates those characteristic leopard spots on the crust—a mark of
                authentic Neapolitan-style pizza and proof of perfect wood-fired cooking.
              </p>
            </div>
            <img
              src="/images/team/serving.jpg"
              alt="Serving pizza"
              class="w-48 h-32 object-cover rounded-lg shadow-md hidden md:block"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Media Features -->
  <section class="py-20 bg-wood-50">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl md:text-5xl font-heading font-bold text-wood-900 mb-4">
            As Featured In
          </h2>
          <p class="text-lg text-wood-600">
            Recognized by local and regional publications
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
          <div class="bg-white p-8 rounded-lg shadow-lg">
            <div class="text-2xl font-bold text-wood-800 mb-3">805 Living</div>
            <p class="text-wood-600 mb-4">
              Featured in 805 Living magazine for bringing authentic wood-fired pizza catering to Ventura County's events.
            </p>
            <a href="#" class="text-fire-600 font-semibold hover:text-fire-700 transition-colors">
              Read Article →
            </a>
          </div>

          <div class="bg-white p-8 rounded-lg shadow-lg">
            <div class="text-2xl font-bold text-wood-800 mb-3">VoyageLA</div>
            <p class="text-wood-600 mb-4">
              Victor shared his journey and the inspiration behind Woodstock Farina in an exclusive VoyageLA interview.
            </p>
            <a href="#" class="text-fire-600 font-semibold hover:text-fire-700 transition-colors">
              Read Interview →
            </a>
          </div>

          <div class="bg-white p-8 rounded-lg shadow-lg">
            <div class="text-2xl font-bold text-wood-800 mb-3">CANVASREBEL</div>
            <p class="text-wood-600 mb-4">
              An in-depth look at the story behind the business and what makes Woodstock Farina unique in the catering industry.
            </p>
            <a href="#" class="text-fire-600 font-semibold hover:text-fire-700 transition-colors">
              Read Story →
            </a>
          </div>

          <div class="bg-white p-8 rounded-lg shadow-lg">
            <div class="text-2xl font-bold text-wood-800 mb-3">Voiced Podcast</div>
            <p class="text-wood-600 mb-4">
              Listen to Victor discuss his heritage, business journey, and passion for wood-fired cooking on the Voiced Podcast.
            </p>
            <a href="#" class="text-fire-600 font-semibold hover:text-fire-700 transition-colors">
              Listen Now →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl md:text-5xl font-heading font-bold text-wood-900 mb-4">
            Our Values
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex gap-4">
            <div class="flex-shrink-0 text-3xl">🤝</div>
            <div>
              <h3 class="text-xl font-heading font-bold text-wood-900 mb-2">Community First</h3>
              <p class="text-wood-600">
                We're proud to serve Ventura County and build relationships with our clients. Every event is personal to us.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 text-3xl">✨</div>
            <div>
              <h3 class="text-xl font-heading font-bold text-wood-900 mb-2">Quality Ingredients</h3>
              <p class="text-wood-600">
                We use only the freshest, highest-quality ingredients and source locally whenever possible.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 text-3xl">💯</div>
            <div>
              <h3 class="text-xl font-heading font-bold text-wood-900 mb-2">Authenticity</h3>
              <p class="text-wood-600">
                From our recipes to our cooking methods, we stay true to traditional wood-fired techniques and Mexican flavors.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 text-3xl">❤️</div>
            <div>
              <h3 class="text-xl font-heading font-bold text-wood-900 mb-2">Passion & Pride</h3>
              <p class="text-wood-600">
                Every pizza we make carries the pride of our heritage and the passion for exceptional food.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-br from-fire-600 to-fire-700 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-4xl md:text-5xl font-heading font-bold mb-6">
        Let's Make Your Event Special
      </h2>
      <p class="text-xl mb-8 max-w-2xl mx-auto">
        Ready to bring authentic wood-fired pizza to your celebration?
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/booking"
          class="bg-white text-fire-600 px-8 py-4 rounded-full font-semibold text-lg hover:bg-wood-50 transition-all transform hover:scale-105"
        >
          Book Your Event
        </a>
        <a
          href="/contact"
          class="bg-fire-800 text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-fire-900 transition-all transform hover:scale-105"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>
